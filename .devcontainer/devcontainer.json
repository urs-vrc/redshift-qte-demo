{
  "name": "Bun",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "forwardPorts": [4000, 9400, 9500, 9900],
  "portsAttributes": {
    "4000": { "label": "Encore API", "onAutoForward": "notify" },
    "9400": { "label": "Encore Dashboard", "onAutoForward": "notify" },
    "3000": { "label": "Frontend", "onAutoForward": "openBrowser" }
  },
  "runArgs": ["--privileged", "--cap-add=NET_ADMIN", "--cap-add=NET_RAW"],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "upgradePackages": true,
      "username": "vscode",
      "userUid": 1000,
      "userGid": 1000
    },
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "ca-certificates,socat"
    },
    "ghcr.io/devcontainers-extra/features/bash-command:1": {
      "command": "sudo update-ca-certificates --fresh"
    },
    "ghcr.io/devcontainers/features/node:2": {
      "version": "lts",
      "pnpmVersion": "latest"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma"
      ]
    }
  },
  "postCreateCommand": "curl -L https://encore.dev/install.sh | bash && echo 'export PATH=\"$HOME/.encore/bin:$PATH\"' >> ~/.bashrc && echo 'export PATH=\"$HOME/.encore/bin:$PATH\"' >> ~/.profile",
  "postStartCommand": "sudo rm -f /var/run/docker.pid && ( sudo dockerd --iptables=false > /dev/null 2>&1 & ) && sleep 15",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.encore/bin",
    "ENCORE_RUNTIME_LIB": "/home/vscode/.encore/runtimes/js/encore-runtime.node"
  }
}
